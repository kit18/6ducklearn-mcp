# Hosted 6DuckLearn MCP defaults.
SIXDUCK_PUBLIC_BASE_URL=https://6ducklearn.com
SIXDUCK_OAUTH_RESOURCE=https://6ducklearn.com/mcp
SIXDUCK_OAUTH_SCOPE=mcp:read runtime:connect control:read

# Local connector runtime. Prefer the OAuth login flow instead of storing tokens here.
SIXDUCK_RUNTIME_TYPE=codex
SIXDUCK_CODEX_CWD=/absolute/path/to/your/workspace
SIXDUCK_CODEX_QUIET_PROFILE=true

